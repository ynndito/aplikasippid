<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Informasi PPID - KPU Kota Probolinggo</title>
    <meta name="description" content="Portal Sistem Informasi PPID KPU Kota Probolinggo - Pejabat Pengelola Informasi dan Dokumentasi. Akses informasi publik dengan mudah dan transparan.">
    <meta name="theme-color" content="#800000">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#fdf2f2',
                            100: '#fbe4e4',
                            500: '#800000',
                            600: '#800000',
                            700: '#660000',
                        },
                    },
                },
            },
        }
    </script>
    <style>
        * {
            scrollbar-width: thin;
        }
        .soft-shadow {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <!-- HEADER/NAVBAR -->
    <header class="bg-white soft-shadow sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center gap-3">
                    <img src="kpu-logo.jpg" alt="KPU Logo" class="w-12 h-12 rounded-lg object-cover">
                    <div class="flex flex-col">
                        <span class="font-bold text-gray-800 text-sm leading-tight">KPU KOTA PROBOLINGGO</span>
                        <span class="text-xs text-gray-600">Pejabat Pengelola Informasi dan Dokumentasi</span>
                    </div>
                </div>
                <nav class="hidden md:flex gap-6 items-center">
                    <button onclick="showSection('landing')" class="text-gray-700 hover:text-primary-600 transition">Beranda</button>
                    <button onclick="showSection('about')" class="text-gray-700 hover:text-primary-600 transition">Tentang PPID</button>
                    <button onclick="showSection('daftar')" class="text-gray-700 hover:text-primary-600 transition">Daftar Informasi</button>
                    <button onclick="showSection('dokumen')" class="text-gray-700 hover:text-primary-600 transition">Dokumen Publik</button>
                    <button onclick="showSection('berita')" class="text-gray-700 hover:text-primary-600 transition">Berita</button>
                    <button onclick="showSection('permohonan')" class="text-gray-700 hover:text-primary-600 transition">Ajukan Permohonan</button>
                    <button onclick="showSection('login')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition">Login</button>
                </nav>
                <button onclick="toggleMobileMenu()" class="md:hidden bg-gray-100 p-2 rounded-lg">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </div>
            <!-- Mobile Menu -->
            <div id="mobileMenu" class="hidden md:hidden pb-4 border-t">
                <button onclick="showSection('landing')" class="block w-full text-left py-2 px-4 hover:bg-gray-100">Beranda</button>
                <button onclick="showSection('about')" class="block w-full text-left py-2 px-4 hover:bg-gray-100">Tentang PPID</button>
                <button onclick="showSection('daftar')" class="block w-full text-left py-2 px-4 hover:bg-gray-100">Daftar Informasi</button>
                <button onclick="showSection('dokumen')" class="block w-full text-left py-2 px-4 hover:bg-gray-100">Dokumen Publik</button>
                <button onclick="showSection('berita')" class="block w-full text-left py-2 px-4 hover:bg-gray-100">Berita</button>
                <button onclick="showSection('permohonan')" class="block w-full text-left py-2 px-4 hover:bg-gray-100">Ajukan Permohonan</button>
                <button onclick="showSection('login')" class="block w-full text-left py-2 px-4 bg-primary-600 text-white rounded-lg mt-2">Login</button>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- LANDING PAGE -->
        <section id="landing" class="fade-in">
            <!-- Hero Section -->
            <div class="relative rounded-2xl p-8 md:p-16 mb-16 soft-shadow overflow-hidden" style="background-image: url('hero-bg.jpg'); background-size: cover; background-position: center;">
                <div class="absolute inset-0 bg-black opacity-40"></div>
                <div class="relative z-10">
                    <h1 class="text-4xl md:text-5xl font-bold mb-4 text-white">Sistem Informasi PPID</h1>
                    <p class="text-lg mb-8 text-white opacity-90">Pusat Informasi Publik dan Dokumentasi. Akses informasi publik dengan mudah dan transparan.</p>
                    <button onclick="showSection('permohonan')" class="bg-white text-primary-600 px-8 py-3 rounded-xl font-semibold hover:bg-gray-100 transition">
                        Ajukan Permohonan
                    </button>
                </div>
            </div>

            <!-- Search & Filter Section -->
            <div class="bg-white rounded-2xl p-8 mb-16 soft-shadow">
                <h2 class="text-2xl font-bold mb-6">Cari Dokumen</h2>
                <div class="flex flex-col md:flex-row gap-4">
                    <input type="text" id="searchInput" placeholder="Cari dokumen..." class="flex-1 px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500" onkeyup="filterDocuments()">
                    <select id="categoryFilter" class="px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500" onchange="filterDocuments()">
                        <option value="">Semua Kategori</option>
                        <option value="Peraturan">Peraturan</option>
                        <option value="Keputusan">Keputusan</option>
                        <option value="Laporan">Laporan</option>
                        <option value="Rencana">Rencana & Program</option>
                    </select>
                    <select id="yearFilter" class="px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500" onchange="filterDocuments()">
                        <option value="">Semua Tahun</option>
                        <option value="2024">2024</option>
                        <option value="2023">2023</option>
                        <option value="2022">2022</option>
                    </select>
                </div>
            </div>

            <!-- Popular Documents -->
            <div class="mb-16">
                <h2 class="text-2xl font-bold mb-6">Informasi Publik Populer</h2>
                <div class="grid md:grid-cols-3 gap-6">
                    <div class="bg-white rounded-2xl p-6 soft-shadow hover:shadow-lg transition cursor-pointer" onclick="showDetail(0)">
                        <div class="bg-primary-100 w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6 text-primary-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 1 1 0 000 2H6V5a2 2 0 012-2h4a2 2 0 012 2v2h2a1 1 0 100 2h-1v10a2 2 0 01-2 2H6a2 2 0 01-2-2V9H3a1 1 0 110-2h1V5zm6 11a1 1 0 100-2 1 1 0 000 2zm-4-1a1 1 0 11-2 0 1 1 0 012 0zm10-1a1 1 0 100-2 1 1 0 000 2z"></path></svg>
                        </div>
                        <h3 class="font-bold text-lg mb-2">Peraturan Pelayanan 2024</h3>
                        <p class="text-gray-600 text-sm mb-4">Peraturan mengenai standar pelayanan publik tahun 2024.</p>
                        <div class="flex items-center justify-between text-sm">
                            <span class="bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-xs font-semibold">Peraturan</span>
                            <span class="text-gray-500">2024</span>
                        </div>
                    </div>
                    <div class="bg-white rounded-2xl p-6 soft-shadow hover:shadow-lg transition cursor-pointer" onclick="showDetail(1)">
                        <div class="bg-blue-100 w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path></svg>
                        </div>
                        <h3 class="font-bold text-lg mb-2">Laporan Tahunan 2023</h3>
                        <p class="text-gray-600 text-sm mb-4">Laporan kinerja dan pencapaian tahun 2023.</p>
                        <div class="flex items-center justify-between text-sm">
                            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-semibold">Laporan</span>
                            <span class="text-gray-500">2023</span>
                        </div>
                    </div>
                    <div class="bg-white rounded-2xl p-6 soft-shadow hover:shadow-lg transition cursor-pointer" onclick="showDetail(2)">
                        <div class="bg-green-100 w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path></svg>
                        </div>
                        <h3 class="font-bold text-lg mb-2">Rencana Kerja 2024</h3>
                        <p class="text-gray-600 text-sm mb-4">Rencana strategis dan program kerja tahun 2024.</p>
                        <div class="flex items-center justify-between text-sm">
                            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-semibold">Rencana</span>
                            <span class="text-gray-500">2024</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Latest Documents -->
            <div>
                <h2 class="text-2xl font-bold mb-6">Informasi Terbaru</h2>
                <div class="space-y-4">
                    <div class="bg-white rounded-2xl p-6 soft-shadow hover:shadow-lg transition flex items-center justify-between cursor-pointer" onclick="showDetail(3)">
                        <div>
                            <h3 class="font-bold text-lg">Surat Edaran Pengumuman</h3>
                            <p class="text-gray-600 text-sm">Kategori: Keputusan | Tanggal: 10 Februari 2024</p>
                        </div>
                        <button class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700">Detail</button>
                    </div>
                    <div class="bg-white rounded-2xl p-6 soft-shadow hover:shadow-lg transition flex items-center justify-between cursor-pointer" onclick="showDetail(4)">
                        <div>
                            <h3 class="font-bold text-lg">Panduan Tata Cara</h3>
                            <p class="text-gray-600 text-sm">Kategori: Peraturan | Tanggal: 08 Februari 2024</p>
                        </div>
                        <button class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700">Detail</button>
                    </div>
                </div>
            </div>
        </section>

        <!-- ABOUT SECTION -->
        <section id="about" class="fade-in hidden">
            <div class="bg-white rounded-2xl p-8 soft-shadow">
                <h1 class="text-3xl font-bold mb-6">Tentang PPID</h1>
                <div class="prose max-w-none space-y-4 text-gray-700">
                    <p>Pusat Informasi Publik dan Dokumentasi (PPID) adalah lembaga yang bertanggung jawab atas pengelolaan dan penyediaan informasi publik kepada masyarakat.</p>
                    <p>Kami berkomitmen untuk meningkatkan transparansi dan akuntabilitas pemerintah melalui akses informasi yang mudah, cepat, dan akurat.</p>
                    <h2 class="text-2xl font-bold mt-6 mb-4">Visi & Misi</h2>
                    <p><strong>Visi:</strong> Menjadi pusat informasi publik yang terpercaya dan transparan.</p>
                    <p><strong>Misi:</strong> Menyediakan akses informasi publik yang mudah, cepat, dan berkualitas untuk semua kalangan.</p>
                </div>
            </div>
        </section>

        <!-- DAFTAR INFORMASI SECTION -->
        <section id="daftar" class="fade-in hidden">
            <h1 class="text-3xl font-bold mb-8">Daftar Informasi Publik</h1>
            <div class="bg-white rounded-2xl overflow-hidden soft-shadow">
                <table class="w-full">
                    <thead class="bg-primary-600 text-white">
                        <tr>
                            <th class="px-6 py-4 text-left">Judul</th>
                            <th class="px-6 py-4 text-left">Kategori</th>
                            <th class="px-6 py-4 text-left">Tahun</th>
                            <th class="px-6 py-4 text-left">Tanggal</th>
                            <th class="px-6 py-4 text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="dokumentTable" class="divide-y">
                    </tbody>
                </table>
            </div>
            <div id="pagination" class="flex justify-center gap-2 mt-8"></div>
        </section>

        <!-- DOKUMEN PUBLIK SECTION -->
        <section id="dokumen" class="fade-in hidden">
            <h1 class="text-3xl font-bold mb-8">Dokumen Publik</h1>
            <div class="grid md:grid-cols-2 gap-6" id="dokumentGrid"></div>
        </section>

        <!-- BERITA SECTION -->
        <section id="berita" class="fade-in hidden">
            <h1 class="text-3xl font-bold mb-8">Berita</h1>
            <div class="grid md:grid-cols-3 gap-6" id="beritaGrid"></div>
        </section>

        <!-- FORM PERMOHONAN SECTION -->
        <section id="permohonan" class="fade-in hidden">
            <h1 class="text-3xl font-bold mb-8">Ajukan Permohonan Informasi</h1>
            <div class="bg-white rounded-2xl p-8 soft-shadow max-w-2xl mx-auto">
                <form onsubmit="submitPermohonan(event)">
                    <div class="mb-6">
                        <label class="block font-semibold mb-2">Nama Lengkap</label>
                        <input type="text" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500" placeholder="Masukkan nama lengkap">
                    </div>
                    <div class="mb-6">
                        <label class="block font-semibold mb-2">Email</label>
                        <input type="email" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500" placeholder="Masukkan email">
                    </div>
                    <div class="mb-6">
                        <label class="block font-semibold mb-2">Nomor Telepon</label>
                        <input type="tel" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500" placeholder="Masukkan nomor telepon">
                    </div>
                    <div class="mb-6">
                        <label class="block font-semibold mb-2">Informasi yang Diminta</label>
                        <textarea required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500 h-32" placeholder="Jelaskan informasi apa yang Anda minta..."></textarea>
                    </div>
                    <div class="mb-6">
                        <label class="block font-semibold mb-2">Cara Penerimaan</label>
                        <select required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500">
                            <option value="">Pilih cara penerimaan</option>
                            <option value="Email">Email</option>
                            <option value="Ditempat">Di Tempat</option>
                            <option value="Pos">Pos</option>
                        </select>
                    </div>
                    <button type="submit" class="w-full bg-primary-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-primary-700 transition">Kirim Permohonan</button>
                </form>
            </div>
        </section>

        <!-- LOGIN SECTION -->
        <section id="login" class="fade-in hidden">
            <div class="bg-white rounded-2xl p-8 soft-shadow max-w-md mx-auto">
                <h1 class="text-3xl font-bold mb-8 text-center">Login</h1>
                <form onsubmit="handleLogin(event)">
                    <div class="mb-6">
                        <label class="block font-semibold mb-2">Email</label>
                        <input type="email" id="loginEmail" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500" placeholder="Masukkan email">
                    </div>
                    <div class="mb-6">
                        <label class="block font-semibold mb-2">Password</label>
                        <input type="password" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500" placeholder="Masukkan password">
                    </div>
                    <button type="submit" class="w-full bg-primary-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-primary-700 transition">Login</button>
                </form>
            </div>
        </section>

        <!-- ADMIN DASHBOARD -->
        <section id="adminDashboard" class="fade-in hidden">
            <div class="grid md:grid-cols-4 gap-6 mb-8">
                <div class="bg-white rounded-2xl p-6 soft-shadow">
                    <div class="text-4xl font-bold text-primary-600">156</div>
                    <div class="text-gray-600 mt-2">Total Dokumen</div>
                </div>
                <div class="bg-white rounded-2xl p-6 soft-shadow">
                    <div class="text-4xl font-bold text-blue-600">42</div>
                    <div class="text-gray-600 mt-2">Permohonan Baru</div>
                </div>
                <div class="bg-white rounded-2xl p-6 soft-shadow">
                    <div class="text-4xl font-bold text-green-600">38</div>
                    <div class="text-gray-600 mt-2">Permohonan Selesai</div>
                </div>
                <div class="bg-white rounded-2xl p-6 soft-shadow">
                    <div class="text-4xl font-bold text-orange-600">4</div>
                    <div class="text-gray-600 mt-2">Pending</div>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <!-- Sidebar Navigation -->
                <div class="bg-white rounded-2xl p-6 soft-shadow h-fit">
                    <h2 class="font-bold text-lg mb-4">Menu Admin</h2>
                    <button onclick="showSection('adminDashboard')" class="block w-full text-left py-3 px-4 rounded-lg bg-primary-100 text-primary-700 font-semibold mb-2">Dashboard</button>
                    <button onclick="showSection('kelolaDokumen')" class="block w-full text-left py-3 px-4 rounded-lg hover:bg-gray-100 transition mb-2">Kelola Dokumen</button>
                    <button onclick="showSection('kelolaDokumen')" class="block w-full text-left py-3 px-4 rounded-lg hover:bg-gray-100 transition mb-2">Status Permohonan</button>
                    <button onclick="logout()" class="block w-full text-left py-3 px-4 rounded-lg hover:bg-red-50 text-red-600 transition">Logout</button>
                </div>

                <!-- Permohonan Table -->
                <div class="bg-white rounded-2xl p-6 soft-shadow overflow-x-auto">
                    <h2 class="font-bold text-lg mb-4">Permohonan Terbaru</h2>
                    <table class="w-full text-sm">
                        <thead class="bg-gray-100">
                            <tr>
                                <th class="px-4 py-2 text-left">Nama</th>
                                <th class="px-4 py-2 text-left">Status</th>
                                <th class="px-4 py-2 text-left">Tanggal</th>
                            </tr>
                        </thead>
                        <tbody id="permohonanAdminTable" class="divide-y">
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- KELOLA DOKUMEN SECTION -->
        <section id="kelolaDokumen" class="fade-in hidden">
            <h1 class="text-3xl font-bold mb-8">Kelola Dokumen</h1>
            <button onclick="openAddDocumentModal()" class="bg-primary-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-primary-700 mb-6">+ Tambah Dokumen</button>
            
            <div class="bg-white rounded-2xl overflow-hidden soft-shadow">
                <table class="w-full">
                    <thead class="bg-primary-600 text-white">
                        <tr>
                            <th class="px-6 py-4 text-left">Judul</th>
                            <th class="px-6 py-4 text-left">Kategori</th>
                            <th class="px-6 py-4 text-left">Tahun</th>
                            <th class="px-6 py-4 text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="kelolaDokumenTable" class="divide-y">
                    </tbody>
                </table>
            </div>
        </section>

        <!-- USER DASHBOARD -->
        <section id="userDashboard" class="fade-in hidden">
            <h1 class="text-3xl font-bold mb-8">Dashboard User</h1>
            <div class="grid md:grid-cols-2 gap-8">
                <!-- Menu -->
                <div class="bg-white rounded-2xl p-6 soft-shadow h-fit">
                    <h2 class="font-bold text-lg mb-4">Menu</h2>
                    <button onclick="showSection('permohonan')" class="block w-full text-left py-3 px-4 rounded-lg hover:bg-gray-100 transition mb-2">Ajukan Permohonan</button>
                    <button onclick="showStatusPermohonan()" class="block w-full text-left py-3 px-4 rounded-lg hover:bg-gray-100 transition mb-2">Status Permohonan</button>
                    <button onclick="logout()" class="block w-full text-left py-3 px-4 rounded-lg hover:bg-red-50 text-red-600 transition">Logout</button>
                </div>

                <!-- Status Permohonan -->
                <div class="bg-white rounded-2xl p-6 soft-shadow">
                    <h2 class="font-bold text-lg mb-4">Status Permohonan Saya</h2>
                    <div id="userPermohonanTable" class="space-y-4"></div>
                </div>
            </div>
        </section>

    </main>

    <!-- FOOTER -->
    <footer class="bg-primary-600 text-white mt-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid md:grid-cols-3 gap-8">
                <div>
                    <h3 class="font-bold text-lg mb-4">KPU Kota Probolinggo</h3>
                    <p class="text-white opacity-90">Jalan Pendidikan No. 45<br>Kota Probolinggo, Jawa Timur 67200<br>Indonesia</p>
                </div>
                <div>
                    <h3 class="font-bold text-lg mb-4">Kontak</h3>
                    <p class="text-white opacity-90">Telepon: (0335) 421-234<br>Email: ppid@kpuprobolinggo.go.id<br>Jam Kerja: Senin-Jumat 08:00-16:00</p>
                </div>
                <div>
                    <h3 class="font-bold text-lg mb-4">Layanan Publik</h3>
                    <p class="text-white opacity-90">Sistem Informasi PPID<br>Pusat Informasi dan Dokumentasi<br>KPU Kota Probolinggo</p>
                </div>
            </div>
            <div class="border-t border-white border-opacity-20 mt-8 pt-8 text-center text-white opacity-90">
                <p>&copy; 2026 KPU Kota Probolinggo. Semua hak dilindungi.</p>
            </div>
        </div>
    </footer>

    <script>
        // DUMMY DATA
        const documents = [
            { id: 1, title: 'Peraturan Pelayanan 2024', category: 'Peraturan', year: 2024, date: '15 Januari 2024', pdfUrl: 'https://www.w3.org/WAI/WCAG21/Techniques/pdf/img/button.pdf' },
            { id: 2, title: 'Laporan Tahunan 2023', category: 'Laporan', year: 2023, date: '10 Januari 2024', pdfUrl: 'https://www.w3.org/WAI/WCAG21/Techniques/pdf/img/button.pdf' },
            { id: 3, title: 'Rencana Kerja 2024', category: 'Rencana', year: 2024, date: '05 Januari 2024', pdfUrl: 'https://www.w3.org/WAI/WCAG21/Techniques/pdf/img/button.pdf' },
            { id: 4, title: 'Surat Edaran Pengumuman', category: 'Keputusan', year: 2024, date: '10 Februari 2024', pdfUrl: 'https://www.w3.org/WAI/WCAG21/Techniques/pdf/img/button.pdf' },
            { id: 5, title: 'Panduan Tata Cara', category: 'Peraturan', year: 2023, date: '08 Februari 2024', pdfUrl: 'https://www.w3.org/WAI/WCAG21/Techniques/pdf/img/button.pdf' },
            { id: 6, title: 'Keputusan Direktur 2024', category: 'Keputusan', year: 2024, date: '01 Februari 2024', pdfUrl: 'https://www.w3.org/WAI/WCAG21/Techniques/pdf/img/button.pdf' },
        ];

        const news = [
            { id: 1, title: 'Sistem PPID Diluncurkan', excerpt: 'Sistem Informasi PPID baru telah diluncurkan untuk meningkatkan transparansi.', date: '12 Februari 2024' },
            { id: 2, title: 'Pelatihan Operator PPID', excerpt: 'Pelatihan untuk operator PPID dilaksanakan dengan peserta dari seluruh departemen.', date: '10 Februari 2024' },
            { id: 3, title: 'Evaluasi Kinerja PPID', excerpt: 'Hasil evaluasi menunjukkan peningkatan signifikan dalam penyediaan informasi publik.', date: '08 Februari 2024' },
        ];

        const permohonanData = [
            { id: 1, name: 'Budi Santoso', email: 'budi@example.com', status: 'Diproses', date: '12 Februari 2024' },
            { id: 2, name: 'Siti Nurhaliza', email: 'siti@example.com', status: 'Selesai', date: '10 Februari 2024' },
            { id: 3, name: 'Ahmad Wijaya', email: 'ahmad@example.com', status: 'Pending', date: '08 Februari 2024' },
            { id: 4, name: 'Rina Kusuma', email: 'rina@example.com', status: 'Diproses', date: '05 Februari 2024' },
        ];

        let currentUser = null;
        let currentDocumentPreview = null;
        let currentPage = 1;
        const itemsPerPage = 5;

        // Show/Hide Sections
        function showSection(sectionId) {
            document.querySelectorAll('main > section').forEach(s => s.classList.add('hidden'));
            document.getElementById(sectionId).classList.remove('hidden');
            document.getElementById('mobileMenu').classList.add('hidden');
            window.scrollTo(0, 0);
        }

        // Mobile Menu Toggle
        function toggleMobileMenu() {
            document.getElementById('mobileMenu').classList.toggle('hidden');
        }

        // Filter Documents
        function filterDocuments() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const categoryFilter = document.getElementById('categoryFilter').value;
            const yearFilter = document.getElementById('yearFilter').value;

            const filtered = documents.filter(doc => 
                doc.title.toLowerCase().includes(searchTerm) &&
                (!categoryFilter || doc.category === categoryFilter) &&
                (!yearFilter || doc.year.toString() === yearFilter)
            );

            renderDocumentGrid(filtered);
        }

        // Render Document Grid
        function renderDocumentGrid(docs) {
            const grid = document.getElementById('dokumentGrid');
            grid.innerHTML = docs.map(doc => `
                <div class="bg-white rounded-2xl p-6 soft-shadow hover:shadow-lg transition cursor-pointer" onclick="showDetail(${doc.id})">
                    <div class="bg-primary-100 w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-primary-600" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 5.414l4 4v8.586a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"></path></svg>
                    </div>
                    <h3 class="font-bold text-lg mb-2">${doc.title}</h3>
                    <p class="text-gray-600 text-sm mb-4">${doc.date}</p>
                    <div class="flex items-center justify-between">
                        <span class="bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-xs font-semibold">${doc.category}</span>
                        <span class="text-gray-500">${doc.year}</span>
                    </div>
                </div>
            `).join('');
        }

        // Render Document Table
        function renderDocumentTable() {
            const start = (currentPage - 1) * itemsPerPage;
            const end = start + itemsPerPage;
            const paginatedDocs = documents.slice(start, end);

            const table = document.getElementById('dokumentTable');
            table.innerHTML = paginatedDocs.map(doc => `
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4">${doc.title}</td>
                    <td class="px-6 py-4">${doc.category}</td>
                    <td class="px-6 py-4">${doc.year}</td>
                    <td class="px-6 py-4">${doc.date}</td>
                    <td class="px-6 py-4 text-center">
                        <button onclick="showDetail(${doc.id})" class="text-primary-600 hover:text-primary-700 font-semibold">Preview</button>
                        <button onclick="downloadDocument()" class="text-gray-600 hover:text-gray-700 font-semibold ml-4">Download</button>
                    </td>
                </tr>
            `).join('');

            // Pagination
            const totalPages = Math.ceil(documents.length / itemsPerPage);
            const pagination = document.getElementById('pagination');
            pagination.innerHTML = Array.from({length: totalPages}, (_, i) => `
                <button onclick="goToPage(${i + 1})" class="px-4 py-2 rounded-lg ${currentPage === i + 1 ? 'bg-primary-600 text-white' : 'bg-white border border-gray-300 hover:bg-gray-100'}">${i + 1}</button>
            `).join('');
        }

        function goToPage(page) {
            currentPage = page;
            renderDocumentTable();
        }

        // Render News
        function renderNews() {
            const grid = document.getElementById('beritaGrid');
            grid.innerHTML = news.map(item => `
                <div class="bg-white rounded-2xl overflow-hidden soft-shadow hover:shadow-lg transition">
                    <div class="bg-gradient-to-r from-primary-500 to-primary-600 h-40 flex items-center justify-center text-white text-4xl">📰</div>
                    <div class="p-6">
                        <h3 class="font-bold text-lg mb-2">${item.title}</h3>
                        <p class="text-gray-600 text-sm mb-4">${item.excerpt}</p>
                        <div class="text-gray-500 text-sm">${item.date}</div>
                    </div>
                </div>
            `).join('');
        }

        // Show Document Detail (Preview Modal)
        function showDetail(docId) {
            const doc = documents.find(d => d.id === docId);
            if (doc) {
                currentDocumentPreview = doc;
                document.getElementById('previewTitle').textContent = doc.title;
                document.getElementById('previewCategory').textContent = doc.category;
                document.getElementById('previewYear').textContent = doc.year;
                document.getElementById('previewDate').textContent = doc.date;
                document.getElementById('pdfPreview').src = doc.pdfUrl;
                document.getElementById('previewModal').classList.remove('hidden');
            }
        }

        // Close Preview Modal
        function closePreviewModal() {
            document.getElementById('previewModal').classList.add('hidden');
            document.getElementById('pdfPreview').src = '';
        }

        // Download Document
        function downloadDocument() {
            if (currentDocumentPreview) {
                alert(`File "${currentDocumentPreview.title}" telah berhasil diunduh!`);
            }
        }

        // Handle Login
        function handleLogin(e) {
            e.preventDefault();
            const email = document.getElementById('loginEmail').value;
            
            if (email.toLowerCase().includes('admin')) {
                currentUser = { role: 'admin', email };
                renderAdminDashboard();
                showSection('adminDashboard');
            } else {
                currentUser = { role: 'user', email };
                renderUserDashboard();
                showSection('userDashboard');
            }
        }

        // Render Admin Dashboard
        function renderAdminDashboard() {
            const table = document.getElementById('permohonanAdminTable');
            table.innerHTML = permohonanData.map(p => {
                const statusColors = {
                    'Diproses': 'bg-yellow-100 text-yellow-700',
                    'Selesai': 'bg-green-100 text-green-700',
                    'Pending': 'bg-red-100 text-red-700'
                };
                return `
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3">${p.name}</td>
                        <td class="px-4 py-3"><span class="px-3 py-1 rounded-full text-xs font-semibold ${statusColors[p.status]}">${p.status}</span></td>
                        <td class="px-4 py-3">${p.date}</td>
                    </tr>
                `;
            }).join('');

            renderKelolaDokumen();
        }

        // Render Kelola Dokumen
        function renderKelolaDokumen() {
            const table = document.getElementById('kelolaDokumenTable');
            table.innerHTML = documents.map(doc => `
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4">${doc.title}</td>
                    <td class="px-6 py-4">${doc.category}</td>
                    <td class="px-6 py-4">${doc.year}</td>
                    <td class="px-6 py-4 text-center">
                        <button onclick="showDetail(${doc.id})" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">Preview</button>
                        <button onclick="alert('Edit dokumen: ${doc.title}')" class="text-blue-600 hover:text-blue-700 font-semibold text-sm ml-4">Edit</button>
                        <button onclick="alert('Hapus dokumen: ${doc.title}')" class="text-red-600 hover:text-red-700 font-semibold text-sm ml-4">Hapus</button>
                    </td>
                </tr>
            `).join('');
        }

        // Render User Dashboard
        function renderUserDashboard() {
            const table = document.getElementById('userPermohonanTable');
            table.innerHTML = permohonanData.map(p => {
                const statusColors = {
                    'Diproses': 'bg-yellow-100 text-yellow-700',
                    'Selesai': 'bg-green-100 text-green-700',
                    'Pending': 'bg-red-100 text-red-700'
                };
                return `
                    <div class="border rounded-lg p-4 flex justify-between items-center">
                        <div>
                            <h3 class="font-bold">${p.name}</h3>
                            <p class="text-sm text-gray-600">${p.date}</p>
                        </div>
                        <div class="text-right">
                            <span class="px-3 py-1 rounded-full text-xs font-semibold ${statusColors[p.status]}">${p.status}</span>
                            ${p.status === 'Selesai' ? `<button onclick="showDetail(1)" class="block mt-2 text-primary-600 text-sm font-semibold">Preview Jawaban</button>` : ''}
                        </div>
                    </div>
                `;
            }).join('');
        }

        // Show Status Permohonan
        function showStatusPermohonan() {
            renderUserDashboard();
        }

        // Submit Permohonan
        function submitPermohonan(e) {
            e.preventDefault();
            alert('Permohonan Anda telah berhasil dikirim! Anda akan menerima email balasan dalam 3 hari kerja.');
            e.target.reset();
            showSection('landing');
        }

        // Modal Tambah Dokumen
        function openAddDocumentModal() {
            document.getElementById('addDocumentModal').classList.remove('hidden');
        }

        function closeAddDocumentModal() {
            document.getElementById('addDocumentModal').classList.add('hidden');
        }

        function submitAddDocument(e) {
            e.preventDefault();
            alert('Dokumen berhasil ditambahkan!');
            closeAddDocumentModal();
            e.target.reset();
        }

        // Logout
        function logout() {
            currentUser = null;
            showSection('landing');
            alert('Anda telah berhasil logout.');
        }

        // Initialize
        function init() {
            renderDocumentTable();
            renderDocumentGrid(documents);
            renderNews();
        }

        init();
    </script>

</body>
</html>
